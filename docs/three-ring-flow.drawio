        <mxCell id="h" value="enforces / hardens Ring 1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;endArrow=classic;strokeColor=#999999;strokeWidth=2;dashed=1;html=1;fontColor=#666666;" edge="1" parent="1" source="r2b" target="r1h1"><mxGeometry relative="1" as="geometry"/></mxCell>
