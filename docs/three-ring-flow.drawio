<mxfile host="app.diagrams.net" type="device">
  <diagram name="three-ring" id="ringflow">
    <mxGraphModel dx="1400" dy="800" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1680" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="secure-dev-guardrails : the three-ring model (defense in depth with a hard gate)" style="text;html=1;fontSize=20;fontStyle=1;fontColor=#0050b3;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1100" height="36" as="geometry"/></mxCell>

        <mxCell id="legend" value="Legend&#10;• green = developer action / merge&#10;• blue = deterministic hook / CI check&#10;• purple = advisory skill&#10;• gray dashed = policy / bypass path&#10;• red diamond = the merge gate&#10;• yellow = shared standards" style="rounded=0;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=0;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;whiteSpace=wrap;html=1;fontFamily=Helvetica;" vertex="1" parent="1"><mxGeometry x="1320" y="70" width="340" height="160" as="geometry"/></mxCell>

        <!-- RING 1 -->
        <mxCell id="r1" value="Ring 1 : Claude Code layer  (shift-left, on the dev machine)" style="rounded=0;fillColor=#fafafa;strokeColor=#0050b3;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;dashed=1;strokeWidth=2;html=1;" vertex="1" parent="1"><mxGeometry x="40" y="250" width="420" height="520" as="geometry"/></mxCell>
        <mxCell id="r1t" value="developer edits / commits code" style="ellipse;fillColor=#d5e8d4;strokeColor=#82b366;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="70" y="290" width="360" height="50" as="geometry"/></mxCell>
        <mxCell id="r1h1" value="hooks (hard-block, exit 2):&#10;secret-scan · pii-in-logs" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="70" y="360" width="360" height="60" as="geometry"/></mxCell>
        <mxCell id="r1h2" value="hooks (warn / inject):&#10;dangerous-pattern · sensitive-file-context" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="70" y="440" width="360" height="60" as="geometry"/></mxCell>
        <mxCell id="r1s" value="advisory skills:&#10;threat-model · privacy-review · dependency-review · secrets-remediation" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="70" y="520" width="360" height="80" as="geometry"/></mxCell>
        <mxCell id="r1note" value="catches most issues live, but only inside Claude Code" style="text;html=1;fontSize=11;fontColor=#555555;align=left;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="70" y="620" width="360" height="40" as="geometry"/></mxCell>

        <!-- RING 2 -->
        <mxCell id="r2" value="Ring 2 : Managed settings  (org policy)" style="rounded=0;fillColor=#fafafa;strokeColor=#999999;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;dashed=1;strokeWidth=2;html=1;" vertex="1" parent="1"><mxGeometry x="500" y="250" width="360" height="520" as="geometry"/></mxCell>
        <mxCell id="r2a" value="managed-settings.json&#10;pushed via MDM (Jamf / Intune / Ansible)" style="rounded=1;fillColor=#eeeeee;strokeColor=#999999;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="530" y="330" width="300" height="70" as="geometry"/></mxCell>
        <mxCell id="r2b" value="makes Ring 1's hard-block hooks non-overridable org policy: a developer cannot disable them" style="rounded=1;fillColor=#eeeeee;strokeColor=#999999;html=1;whiteSpace=wrap;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="530" y="430" width="300" height="90" as="geometry"/></mxCell>

        <!-- RING 3 -->
        <mxCell id="r3" value="Ring 3 : Server-side CI gate  (the only true merge blocker)" style="rounded=0;fillColor=#fafafa;strokeColor=#0050b3;fontStyle=1;verticalAlign=top;align=left;spacingLeft=10;spacingTop=6;dashed=1;strokeWidth=2;html=1;" vertex="1" parent="1"><mxGeometry x="900" y="250" width="420" height="520" as="geometry"/></mxCell>
        <mxCell id="r3t" value="on every pull request / push (server-side)" style="ellipse;fillColor=#d5e8d4;strokeColor=#82b366;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="930" y="290" width="360" height="50" as="geometry"/></mxCell>
        <mxCell id="r3c" value="gitleaks · semgrep (SEC/PRIV rules) · PII net · dependency audit (SCA) · baseline-expiry gate" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="930" y="360" width="360" height="90" as="geometry"/></mxCell>
        <mxCell id="r3d" value="clean?&#10;(block | warn dial)" style="rhombus;fillColor=#f8cecc;strokeColor=#b85450;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="990" y="480" width="240" height="100" as="geometry"/></mxCell>
        <mxCell id="r3ok" value="merge to main" style="ellipse;fillColor=#d5e8d4;strokeColor=#82b366;html=1;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="930" y="620" width="150" height="60" as="geometry"/></mxCell>
        <mxCell id="r3no" value="merge blocked&#10;fix + re-push" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="1140" y="620" width="150" height="60" as="geometry"/></mxCell>

        <!-- standards band -->
        <mxCell id="std" value="standards/: SEC-* security rules + PRIV-* privacy rules (GDPR + CCPA) + one severity taxonomy.  All three rings cite these IDs, so findings from a hook, a skill, and CI aggregate into one vocabulary." style="shape=cylinder3;size=8;fillColor=#fff2cc;strokeColor=#d6b656;html=1;whiteSpace=wrap;fontStyle=0;direction=south;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="40" y="800" width="1280" height="70" as="geometry"/></mxCell>

